# ── SMTP (required) ──────────────────────────────────────────
# Used for magic-link login emails and daily digest delivery.
# Porkbun: smtp.porkbun.com / 587
# Gmail:   smtp.gmail.com   / 587  (use App Password)
# Outlook: smtp.office365.com / 587
SMTP_HOST=smtp.porkbun.com
SMTP_PORT=587
SMTP_USER=alerts@resalesignal.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true

# ── App (required in production) ─────────────────────────────
# Random string used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Public URL of the site (used for magic-link emails).
# Omit for local dev (defaults to request.url_root).
SITE_URL=https://resalesignal.com

# ── Digest cron trigger ──────────────────────────────────────
# Secret token to protect the POST /digest/run endpoint.
# Your cron service sends: Authorization: Bearer <this value>
# Generate one with: python -c "import secrets; print(secrets.token_hex(16))"
DIGEST_SECRET=change-me-to-a-random-string

# ── Database (required on Railway) ───────────────────────────
# Path to the SQLite database file.
# On Railway, mount a Volume at /data and set this to /data/scraper.db
# so the database survives deploys. Defaults to ./scraper.db locally.
# DATABASE_PATH=/data/scraper.db
